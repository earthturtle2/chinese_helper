# Server
PORT=3000
NODE_ENV=production

# JWT
JWT_SECRET=change-this-to-a-random-secret-string

# Admin (created on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# DeepSeek API (for writing guidance)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Vosk ASR model path
VOSK_MODEL_PATH=./models/vosk-model-small-cn-0.22

# Anti-addiction default (minutes)
DEFAULT_DAILY_LIMIT=40
