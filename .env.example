# Server (default 3001 in code/PM2 if unset; change if port is in use)
PORT=3001
NODE_ENV=production

# 置于 Nginx / 负载均衡之后时设为 1，以便识别客户端 IP（express-rate-limit、req.ip 等）
TRUST_PROXY=1

# JWT — required in production (≥32 chars). In development, if unset, a random per-process secret is used.
JWT_SECRET=

# Admin — both required to create the first admin account when the database is empty
ADMIN_USERNAME=
ADMIN_PASSWORD=

# DeepSeek API (for writing guidance)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Vosk ASR model path
VOSK_MODEL_PATH=./models/vosk-model-small-cn-0.22

# Piper 本地朗读（可选）。npm run fetch-piper 下载模型后，设置 piper 可执行文件路径：
# Windows 示例: PIPER_BIN=D:\tools\piper\piper.exe
# Linux 示例: PIPER_BIN=/opt/piper/piper
# 默认模型为 huayan（花言），使用 espeak 音素，兼容 C++ piper 二进制。
# xiao_ya（小雅）使用 pinyin 音素类型，仅兼容 Python piper-tts ≥1.4，C++ 二进制会报 codepoint 错误。
# 下载 xiao_ya: PIPER_VOICE=xiao_ya npm run fetch-piper
PIPER_BIN=
# PIPER_MODEL=models/piper/zh_CN-huayan-medium.onnx
# 可选：略大于 1 时语速稍慢、句间停顿略舒展（如 1.05）；需 Piper 可执行文件支持 --length_scale
# PIPER_LENGTH_SCALE=1.05
# npm run fetch-piper 下载模型时：国内或服务器访问 HF 超时，可改用镜像（与 huggingface-cli 的 HF_ENDPOINT 一致）
# HF_ENDPOINT=https://hf-mirror.com

# Anti-addiction default (minutes)
DEFAULT_DAILY_LIMIT=40

# --- Client build (client/.env) — optional when API is on another origin ---
# Must include the /api path if your backend mounts there, e.g. https://your-domain.com/api
# VITE_API_BASE_URL=https://your-domain.com/api
