server {
    listen 80;
    server_name chinese.itorange.online;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name chinese.itorange.online;

    ssl_certificate     /etc/letsencrypt/live/chinese.itorange.online/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/chinese.itorange.online/privkey.pem;

    client_max_body_size 10m;

    gzip on;
    gzip_types text/plain text/css application/json application/javascript application/wasm;
    gzip_min_length 1024;

    # Frontend static files
    location / {
        root /data/node-apps/chinese_helper/client/dist;
        try_files $uri $uri/ /index.html;

        location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff2?|ttf|eot|wasm|onnx)$ {
            expires 30d;
            add_header Cache-Control "public, immutable";
        }
    }

    # TTS audio files
    location /audio/ {
        alias /data/node-apps/chinese_helper/data/audio/;
        expires 30d;
        add_header Cache-Control "public";
    }

    # API reverse proxy
    location /api/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
        proxy_read_timeout 60s;
    }
}
